{
  "name": "azure-agentic-infraops",
  "version": "0.10.0",
  "description": "APEX - Agentic Platform Engineering eXperience for Azure. Verified. Well-Architected. Deployable.",
  "private": true,
  "scripts": {
    "prepare": "lefthook install",
    "lint:md": "markdownlint-cli2",
    "lint:md:fix": "markdownlint-cli2 --fix",
    "lint:links": "find . -name '*.md' ! -path './node_modules/*' ! -path './infra/*' ! -path './site/node_modules/*' ! -path './site/dist/*' | xargs -I {} markdown-link-check {} --config .markdown-link-check.json",
    "lint:links:docs": "find site/src/content/docs \\( -name '*.md' -o -name '*.mdx' \\) ! -path '*/demo/*' | xargs -I {} markdown-link-check {} --config .markdown-link-check-site.json",
    "docs:dev": "cd site && npm run dev",
    "docs:build": "cd site && npm run build",
    "docs:preview": "cd site && npm run preview",
    "validate:artifacts": "node tools/scripts/validate-artifacts.mjs",
    "fix:artifacts": "node tools/scripts/validate-artifacts.mjs --fix",
    "lint:artifact-templates": "node tools/scripts/validate-artifacts.mjs",
    "lint:h2-sync": "node tools/scripts/validate-artifacts.mjs",
    "fix:artifact-h2": "node tools/scripts/validate-artifacts.mjs --fix",
    "lint:version-sync": "node tools/scripts/validate-version-sync.mjs",
    "lint:deprecated-refs": "node tools/scripts/validate-no-deprecated-refs.mjs",
    "lint:mcp-config": "node tools/scripts/validate-mcp-config.mjs",
    "lint:docs-freshness": "node tools/scripts/check-docs-freshness.mjs",
    "validate:agents": "node tools/scripts/validate-agents.mjs",
    "lint:agent-frontmatter": "node tools/scripts/validate-agents.mjs",
    "lint:skills-format": "node tools/scripts/validate-skills.mjs",
    "lint:governance-refs": "node tools/scripts/validate-governance-refs.mjs",
    "test:governance-discovery": "python3 -m pytest .github/skills/azure-governance-discovery/scripts/test_discover.py -q",
    "validate:instruction-checks": "node tools/scripts/validate-instruction-checks.mjs",
    "validate:session-state": "node tools/scripts/validate-session-state.mjs",
    "lint:prose": "vale --config .vale.ini site/src/content/docs/ .github/ README.md || echo 'Vale not installed - run: brew install vale'",
    "lint:json": "node tools/scripts/lint-json.mjs",
    "lint:json-schemas": "node tools/scripts/validate-json-schemas.mjs",
    "lint:yaml": "find . \\( -name '*.yml' -o -name '*.yaml' \\) ! -path './node_modules/*' ! -path './infra/*' -exec yamllint -c .yamllint.yml {} \\; 2>/dev/null || echo 'yamllint not installed - run: pip install yamllint'",
    "lint:python": "cd tools/mcp-servers/azure-pricing && python3 -m ruff check src/ tests/ && cd ../../../tools/apex-recall && python3 -m ruff check src/",
    "lint:python:fix": "cd tools/mcp-servers/azure-pricing && python3 -m ruff check --fix src/ tests/ && cd ../../../tools/apex-recall && python3 -m ruff check --fix src/",
    "test:apex-recall": "python3 -m pytest tools/tests/test_apex_recall/ -q",
    "lint:drawio": "node tools/scripts/validate-drawio-files.mjs",
    "lint:terraform-fmt": "terraform fmt -check -recursive infra/terraform/",
    "validate:terraform": "for dir in infra/terraform/*/; do [ -f \"$dir/main.tf\" ] && (cd \"$dir\" && terraform init -backend=false -input=false > /dev/null 2>&1 && terraform validate) || true; done",
    "validate:vscode": "node tools/scripts/validate-vscode-config.mjs",
    "fetch:deprecations": "node tools/scripts/fetch-azure-deprecations.mjs",
    "snapshot:baseline": "bash tools/scripts/snapshot-agent-context.sh",
    "diff:baseline": "bash tools/scripts/diff-context-baseline.sh",
    "lint:agent-checks": "node tools/scripts/validate-agents.mjs",
    "lint:glob-audit": "node tools/scripts/validate-glob-audit.mjs",
    "lint:model-floors": "node tools/scripts/validate-model-floors.mjs",
    "validate:skills": "node tools/scripts/validate-skills.mjs",
    "lint:skill-references": "node tools/scripts/validate-skills.mjs",
    "lint:orphaned-content": "node tools/scripts/validate-orphaned-content.mjs",
    "validate:session-lock": "node tools/scripts/validate-session-lock.mjs",
    "validate:workflow-graph": "node tools/scripts/validate-workflow-graph.mjs",
    "lint:workflow-table-sync": "node tools/scripts/validate-workflow-table-sync.mjs",
    "validate:agent-registry": "node tools/scripts/validate-agent-registry.mjs",
    "lint:registry-coverage": "node tools/scripts/validate-registry-skill-coverage.mjs",
    "validate:skill-checks": "node tools/scripts/validate-skill-checks.mjs",
    "validate:stale-refs": "node tools/scripts/validate-skills.mjs",
    "lint:model-alignment": "node tools/scripts/validate-agents.mjs",
    "generate:digests": "node tools/scripts/generate-skill-digests.mjs",
    "e2e:validate": "node tools/scripts/validate-e2e-step.mjs all",
    "e2e:benchmark": "node tools/scripts/benchmark-e2e.mjs",
    "e2e:combine": "node tools/scripts/combine-e2e-runs.mjs",
    "export:agent-output-html": "python3 tools/scripts/export-agent-output-html.py",
    "init": "node tools/scripts/init-from-template.mjs",
    "setup": "bash tools/scripts/setup-azure.sh",
    "sync:workflows": "node tools/scripts/sync-workflows.mjs",
    "validate:no-hardcoded-counts": "node tools/scripts/validate-no-hardcoded-counts.mjs",
    "validate:hooks": "node tools/scripts/validate-hooks.mjs",
    "validate:iac-security-baseline": "node tools/scripts/validate-iac-security-baseline.mjs",
    "validate:terminology": "node tools/scripts/validate-terminology.mjs",
    "build:drawio-icons": "python3 tools/scripts/convert-azure-icons-to-drawio.py",
    "build:explorer-graph": "node tools/scripts/generate-explorer-graph.mjs",
    "validate:explorer-graph": "EXPLORER_GRAPH_STRICT=1 node tools/scripts/validate-explorer-graph.mjs",
    "test:hooks": "bash tools/tests/test-hooks.sh",
    "validate:_node": "run-p validate:artifacts validate:agents validate:skills lint:version-sync lint:deprecated-refs lint:mcp-config validate:instruction-checks lint:governance-refs validate:session-state validate:session-lock validate:workflow-graph lint:workflow-table-sync validate:agent-registry lint:registry-coverage validate:skill-checks lint:json lint:json-schemas lint:glob-audit lint:orphaned-content lint:docs-freshness validate:no-hardcoded-counts validate:hooks validate:iac-security-baseline validate:vscode lint:drawio validate:terminology lint:model-floors validate:explorer-graph",
    "validate:_node-ci": "run-p validate:artifacts validate:agents validate:skills lint:version-sync lint:deprecated-refs lint:mcp-config lint:governance-refs validate:instruction-checks validate:session-state validate:session-lock validate:workflow-graph lint:workflow-table-sync validate:agent-registry lint:registry-coverage validate:skill-checks lint:json lint:json-schemas lint:glob-audit lint:orphaned-content validate:vscode lint:drawio lint:model-floors validate:explorer-graph",
    "validate:_external": "run-p lint:md lint:python lint:terraform-fmt validate:terraform test:apex-recall",
    "validate:all": "run-p --continue-on-error validate:_node validate:_external && echo '✅ All validations passed'",
    "audit:quarterly": "run-p lint:glob-audit lint:orphaned-content lint:docs-freshness"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "fast-xml-parser": "^5.7.0",
    "jsdom": "^29.0.1",
    "lefthook": "^2.1.4",
    "markdown-link-check": "^3.14.2",
    "markdownlint-cli2": "^0.21.0",
    "npm-run-all2": "^8.0.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jonathan-vella/azure-agentic-infraops.git"
  },
  "keywords": [
    "azure",
    "bicep",
    "github-copilot",
    "infrastructure-as-code",
    "agents",
    "agentic",
    "well-architected",
    "azure-verified-modules"
  ],
  "author": "Jonathan Vella",
  "license": "MIT",
  "overrides": {
    "undici": ">=7.24.0",
    "dompurify": ">=3.3.2",
    "nanoid": ">=3.3.8",
    "mermaid": ">=11.4.1"
  }
}
